{
  "config": {
    "extends": ".markdownlint.json"
  },
  "globs": [
    "**/*.md",
    "!**/node_modules/**",
    "!**/obj/**",
    "!**/bin/**"
  ],
  // Files to ignore
  "ignores": [
    "**/node_modules/**",
    "**/coverage/**",
    "**/TestResults/**",
    "**/.vscode/**",
    "**/.github/**"
  ],
  // Fix mode settings
  "fix": true,
  // Output formatting
  "outputFormatters": [
    [
      "markdownlint-cli2-formatter-default"
    ]
  ]
}
